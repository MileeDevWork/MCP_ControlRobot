{
  "mcpServers": {
    "local-stdio-calculator": {
      "type": "stdio",
      "command": "python",
      "args": [
        "-u",
        "calculator.py"
      ]
    },
    "robot-control": {
      "type": "stdio",
      "command": "python",
      "args": [
        "-u",
        "robot_control.py"
      ]
    },
    "legal-answer": {
      "type": "stdio",
      "command": "python",
      "args": [
        "-u",
        "legal_answer_server.py"
      ]
    },
    "remote-sse-server": {
      "type": "sse",
      "url": "https://api.example.com/sse",
      "disabled": true
    },
    "remote-http-server": {
      "type": "http",
      "url": "https://api.example.com/mcp",
      "disabled": true
    }
  }
}