{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.com/mcp-controlrobot/scenario.schema.json",
    "title": "MCP Legal QA Scenario",
    "type": "object",
    "required": [
        "schema",
        "metadata",
        "cases"
    ],
    "properties": {
        "schema": {
            "type": "string",
            "const": "mcp.eval.scenario.v1"
        },
        "metadata": {
            "type": "object",
            "required": [
                "dataset_id",
                "dataset_name"
            ],
            "properties": {
                "dataset_id": {
                    "type": "string",
                    "minLength": 1
                },
                "dataset_name": {
                    "type": "string",
                    "minLength": 1
                },
                "description": {
                    "type": "string"
                },
                "language": {
                    "type": "string"
                },
                "source": {
                    "type": "string"
                }
            },
            "additionalProperties": true
        },
        "cases": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "case_id",
                    "input",
                    "expected"
                ],
                "properties": {
                    "case_id": {
                        "type": "string",
                        "minLength": 1
                    },
                    "input": {
                        "type": "object",
                        "required": [
                            "query"
                        ],
                        "properties": {
                            "query": {
                                "type": "string",
                                "minLength": 1
                            }
                        },
                        "additionalProperties": true
                    },
                    "expected": {
                        "type": "object",
                        "properties": {
                            "contains": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            },
                            "strict": {
                                "type": "boolean"
                            }
                        },
                        "additionalProperties": true
                    },
                    "category": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    },
                    "tags": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "weight": {
                        "type": "number"
                    }
                },
                "additionalProperties": true
            }
        }
    },
    "additionalProperties": true
}